{
  "name": "litvm-t4-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@3.6.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:preview": "yarn pages:build && wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "pages:deploy": "yarn pages:build && wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "2.2.0",
    "@tanstack/react-query": "5.59.20",
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viem": "2.21.45",
    "wagmi": "2.13.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "1.13.7",
    "@types/node": "20.16.13",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vercel": "37.14.0",
    "wrangler": "3.84.1"
  }
}
